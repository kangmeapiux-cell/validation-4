# ─── Backend (used by SAM local and Lambda) ───────────────────────────────────
# DynamoDB table name for tasks
# In production this is set automatically by SAM template.yaml
TASKS_TABLE=validation-4-tasks-local

# AWS region (auto-injected by Lambda runtime in production)
AWS_REGION=us-east-1

# ─── Frontend (copy to frontend/.env.local for local development) ─────────────
# Base URL of API Gateway — no trailing slash
# Local dev: http://localhost:3000
# Production: https://<api-id>.execute-api.<region>.amazonaws.com/prod
VITE_API_URL=http://localhost:3000

# ─── SAM Local (optional overrides) ──────────────────────────────────────────
# Used by scripts/seed-data.js when targeting local DynamoDB
# AWS_ENDPOINT_URL=http://localhost:8000
